{
  "$schema": "./design-tokens.schema.json",
  "_description": "Design tokens for Print Room Studio — synced from packages/ui/tailwind.config.ts and globals.css. Non-developers can edit brand values here; the Storybook will rebuild automatically.",

  "colors": {
    "brand": {
      "primary": "#2B3990",
      "primaryDark": "#232E73",
      "primarySoft": "#3A4BA8",
      "accent": "#0900FF",
      "accentLime": "#F1FFA5"
    },
    "figma": {
      "background": "#F5F2ED",
      "button": "#747A7B",
      "hover": "#0900FF",
      "border": "#2C2C2C"
    },
    "ui": {
      "background": "hsl(0 0% 100%)",
      "foreground": "hsl(0 0% 3.9%)",
      "card": "hsl(0 0% 100%)",
      "cardForeground": "hsl(0 0% 3.9%)",
      "popover": "hsl(0 0% 100%)",
      "popoverForeground": "hsl(0 0% 3.9%)",
      "primary": "hsl(0 0% 9%)",
      "primaryForeground": "hsl(0 0% 98%)",
      "secondary": "hsl(0 0% 96.1%)",
      "secondaryForeground": "hsl(0 0% 9%)",
      "muted": "hsl(0 0% 96.1%)",
      "mutedForeground": "hsl(0 0% 45.1%)",
      "accent": "hsl(0 0% 96.1%)",
      "accentForeground": "hsl(0 0% 9%)",
      "destructive": "hsl(0 84.2% 60.2%)",
      "destructiveForeground": "hsl(0 0% 98%)",
      "border": "hsl(0 0% 89.8%)",
      "input": "hsl(0 0% 89.8%)",
      "ring": "hsl(0 0% 3.9%)"
    },
    "uiDark": {
      "background": "hsl(0 0% 3.9%)",
      "foreground": "hsl(0 0% 98%)",
      "primary": "hsl(0 0% 98%)",
      "primaryForeground": "hsl(0 0% 9%)",
      "secondary": "hsl(0 0% 14.9%)",
      "muted": "hsl(0 0% 14.9%)",
      "mutedForeground": "hsl(0 0% 63.9%)",
      "border": "hsl(0 0% 14.9%)",
      "ring": "hsl(0 0% 83.1%)"
    },
    "palette": {
      "primary": {
        "50": "#f5f3ff", "100": "#ede9fe", "200": "#ddd6fe", "300": "#c4b5fd",
        "400": "#a78bfa", "500": "#8b5cf6", "600": "#7c3aed", "700": "#6d28d9",
        "800": "#5b21b6", "900": "#4c1d95", "950": "#2e1065"
      },
      "secondary": {
        "50": "#f7fee7", "100": "#ecfccb", "200": "#d9f99d", "300": "#bef264",
        "400": "#a3e635", "500": "#84cc16", "600": "#65a30d", "700": "#4d7c0f",
        "800": "#3f6212", "900": "#365314", "950": "#1a2e05"
      },
      "accent": {
        "50": "#ecfdf5", "100": "#d1fae5", "200": "#a7f3d0", "300": "#6ee7b7",
        "400": "#34d399", "500": "#10b981", "600": "#059669", "700": "#047857",
        "800": "#065f46", "900": "#064e3b", "950": "#022c22"
      },
      "neutral": {
        "0": "#ffffff", "50": "#f8fafc", "100": "#f1f5f9", "200": "#e2e8f0",
        "300": "#cbd5e1", "400": "#94a3b8", "500": "#64748b", "600": "#475569",
        "700": "#334155", "800": "#1e293b", "900": "#0f172a", "950": "#020617"
      }
    },
    "status": {
      "success": "#10b981",
      "warning": "#f59e0b",
      "error": "#ef4444",
      "info": "#3b82f6"
    },
    "chart": {
      "1": "hsl(12 76% 61%)",
      "2": "hsl(173 58% 39%)",
      "3": "hsl(197 37% 24%)",
      "4": "hsl(43 74% 66%)",
      "5": "hsl(27 87% 67%)"
    }
  },

  "typography": {
    "fontFamily": {
      "sans": "'DM Sans', system-ui, sans-serif",
      "display": "'DM Sans', system-ui, sans-serif",
      "mono": "JetBrains Mono, monospace",
      "techPack": "'Roboto', 'DM Sans', system-ui, sans-serif",
      "techPackDisplay": "'D-DINExp', 'Roboto', 'DM Sans', system-ui, sans-serif"
    },
    "fontSize": {
      "display-2xl": "3rem / 3.75rem (700)",
      "display-xl": "2.5rem / 3rem (700)",
      "display-lg": "2rem / 2.5rem (600)",
      "display-md": "1.75rem / 2.25rem (600)",
      "display-sm": "1.5rem / 2rem (600)",
      "xl": "1.25rem / 1.875rem (500)",
      "lg": "1.125rem / 1.75rem (500)",
      "md": "1rem / 1.5rem (400)",
      "sm": "0.875rem / 1.25rem (400)",
      "xs": "0.75rem / 1.125rem (400)"
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    }
  },

  "spacing": {
    "0.5": "0.125rem",
    "1": "0.25rem",
    "1.5": "0.375rem",
    "2": "0.5rem",
    "2.5": "0.625rem",
    "3": "0.75rem",
    "3.5": "0.875rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "7": "1.75rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },

  "borderRadius": {
    "none": "0px",
    "sm": "calc(var(--radius) - 4px)",
    "DEFAULT": "6px",
    "md": "calc(var(--radius) - 2px)",
    "lg": "var(--radius)",
    "xl": "16px",
    "2xl": "20px",
    "3xl": "24px",
    "full": "9999px",
    "button": "8px",
    "card": "12px",
    "modal": "16px",
    "pill": "100px",
    "_radiusDefault": "0.5rem",
    "_radiusTechPack": "0.9rem"
  },

  "shadows": {
    "xs": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "sm": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
    "xl": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
    "button": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "buttonHover": "0 4px 8px 0 rgb(0 0 0 / 0.1)",
    "card": "0 2px 4px 0 rgb(0 0 0 / 0.06), 0 1px 2px 0 rgb(0 0 0 / 0.04)",
    "modal": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 10px 10px -5px rgb(0 0 0 / 0.04)",
    "glassSm": "0 2px 8px rgba(0 0 0 / 0.04), 0 1px 2px rgba(0 0 0 / 0.06)",
    "glassMd": "0 4px 16px rgba(0 0 0 / 0.06), 0 2px 4px rgba(0 0 0 / 0.04)",
    "glassLg": "0 8px 32px rgba(0 0 0 / 0.08), 0 4px 8px rgba(0 0 0 / 0.04)",
    "glassXl": "0 16px 48px rgba(0 0 0 / 0.12), 0 8px 16px rgba(0 0 0 / 0.06)"
  },

  "animation": {
    "fadeIn": "fade-in 0.2s ease-out",
    "slideIn": "slide-in 0.3s ease-out",
    "bounceIn": "bounce-in 0.4s ease-out",
    "accordionDown": "accordion-down 0.2s ease-out",
    "accordionUp": "accordion-up 0.2s ease-out",
    "shimmer": "shimmer 6s infinite",
    "sparkle": "sparkle 5s infinite"
  }
}
